{
  "$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/oxlint-config-json-schema/main/schema.json",
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "warn",
    "eqeqeq": "error",
    "no-var": "error",
    "prefer-const": "error",
    "no-eval": "error",
    "no-implicit-coercion": "warn",
    "no-throw-literal": "error"
  },
  "ignorePatterns": ["node_modules", "dist", "build", "*.d.ts"]
}
